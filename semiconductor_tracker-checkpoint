   "source": [
    "\"\"\"\n",
    "Semiconductor Stock Price Tracker\n",
    "Author: Carrington Davis\n",
    "Description: Tracks and visualizes 1-year performance of major semiconductor companies\n",
    "\"\"\"\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "# ── COMPANY DATA ──────────────────────────────────────────────\n",
    "stocks = {\n",
    "    'NVDA':  {'start': 495.0,  'drift': 0.0018, 'vol': 0.032, 'color': '#76b900', 'name': 'NVIDIA'},\n",
    "    'TSM':   {'start': 102.0,  'drift': 0.0008, 'vol': 0.021, 'color': '#e63946', 'name': 'TSMC'},\n",
    "    'AMD':   {'start': 171.0,  'drift': 0.0006, 'vol': 0.028, 'color': '#ed1c24', 'name': 'AMD'},\n",
    "    'INTC':  {'start': 43.0,   'drift': -0.0004,'vol': 0.022, 'color': '#0071c5', 'name': 'Intel'},\n",
    "    'AMAT':  {'start': 182.0,  'drift': 0.0010, 'vol': 0.024, 'color': '#f4a024', 'name': 'Applied Materials'},\n",
    "    'TXN':   {'start': 168.0,  'drift': 0.0005, 'vol': 0.018, 'color': '#c0392b', 'name': 'Texas Instruments'},\n",
    "}\n",
    "\n",
    "# ── SIMULATED DATA (replace with yfinance for live data) ──────\n",
    "import yfinance as yf\n",
    "tickers = list(stocks.keys())\n",
    "df = yf.download(tickers, period='1y', auto_adjust=True)['Close']\n",
    "\n",
    "# ── NORMALIZE TO BASE 100 ─────────────────────────────────────\n",
    "normalized = df / df.iloc[0] * 100\n",
    "\n",
    "# ── CALCULATE RETURNS ─────────────────────────────────────────\n",
    "summary = []\n",
    "for ticker, cfg in stocks.items():\n",
    "    start_p = df[ticker].iloc[0]\n",
    "    end_p   = df[ticker].iloc[-1]\n",
    "    pct     = ((end_p - start_p) / start_p) * 100\n",
    "    vol_ann = df[ticker].pct_change().std() * np.sqrt(252) * 100\n",
    "    summary.append({\n",
    "        'ticker':  ticker,\n",
    "        'name':    cfg['name'],\n",
    "        'start':   start_p,\n",
    "        'end':     end_p,\n",
    "        'return':  pct,\n",
    "        'vol_ann': vol_ann,\n",
    "        'color':   cfg['color'],\n",
    "    })\n",
    "\n",
    "summary.sort(key=lambda x: x['return'], reverse=True)\n",
    "\n",
    "# ── PRINT SUMMARY ─────────────────────────────────────────────\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"  SEMICONDUCTOR STOCK TRACKER — 1 YEAR SUMMARY\")\n",
    "print(\"=\"*60)\n",
    "print(f\"  {'Ticker':<6} {'Company':<22} {'Start':>7} {'End':>7} {'Return':>8} {'Vol':>7}\")\n",
    "print(\"  \" + \"-\"*56)\n",
    "for s in summary:\n",
    "    print(f\"  {s['ticker']:<6} {s['name']:<22} ${s['start']:>6.2f} ${s['end']:>6.2f} {s['return']:>+7.1f}%  {s['vol_ann']:>5.1f}%\")\n",
    "print(\"=\"*60 + \"\\n\")\n",
    "\n",
    "# ── PLOT ──────────────────────────────────────────────────────\n",
    "fig, axes = plt.subplots(2, 1, figsize=(14, 10), facecolor='#0d1117')\n",
    "fig.suptitle('Semiconductor Stock Tracker — 1 Year Performance',\n",
    "             fontsize=16, color='white', fontweight='bold', y=0.98)\n",
    "\n",
    "# Chart 1 — normalized price lines\n",
    "ax1 = axes[0]\n",
    "ax1.set_facecolor('#161b22')\n",
    "for s in summary:\n",
    "    ax1.plot(normalized.index, normalized[s['ticker']],\n",
    "             label=s['ticker'], color=s['color'], linewidth=1.8)\n",
    "\n",
    "ax1.set_title('Normalized Price Performance (Base 100)', color='#8b949e', fontsize=11)\n",
    "ax1.set_ylabel('Indexed Price', color='#8b949e')\n",
    "ax1.tick_params(colors='#8b949e')\n",
    "for spine in ax1.spines.values():\n",
    "    spine.set_color('#30363d')\n",
    "ax1.grid(True, alpha=0.2, color='#30363d')\n",
    "ax1.axhline(y=100, color='#30363d', linestyle='--', linewidth=0.8)\n",
    "ax1.legend(loc='upper left', framealpha=0.3,\n",
    "           facecolor='#161b22', edgecolor='#30363d',\n",
    "           labelcolor='white', fontsize=9)\n",
    "\n",
    "# Chart 2 — return bar chart\n",
    "ax2 = axes[1]\n",
    "ax2.set_facecolor('#161b22')\n",
    "tickers_sorted = [s['ticker'] for s in summary]\n",
    "pcts           = [s['return'] for s in summary]\n",
    "colors         = [s['color']  for s in summary]\n",
    "\n",
    "bars = ax2.bar(tickers_sorted, pcts, color=colors, alpha=0.85, width=0.6)\n",
    "ax2.set_title('1-Year Return (%)', color='#8b949e', fontsize=11)\n",
    "ax2.set_ylabel('Return (%)', color='#8b949e')\n",
    "ax2.tick_params(colors='#8b949e')\n",
    "for spine in ax2.spines.values():\n",
    "    spine.set_color('#30363d')\n",
    "ax2.grid(True, alpha=0.2, color='#30363d', axis='y')\n",
    "ax2.axhline(y=0, color='#8b949e', linewidth=0.8)\n",
    "\n",
    "for bar, pct in zip(bars, pcts):\n",
    "    ypos = bar.get_height() + 0.5 if pct >= 0 else bar.get_height() - 2.5\n",
    "    ax2.text(bar.get_x() + bar.get_width()/2., ypos,\n",
    "             f'{pct:.1f}%', ha='center', va='bottom',\n",
    "             color='white', fontsize=9, fontweight='bold')\n",
    "\n",
    "fig.text(0.01, 0.01,\n",
    "         'Data: simulated  |  Swap in yfinance for live prices  |  github.com/carringtondavis',\n",
    "         color='#484f58', fontsize=8)\n",
    "\n",
    "plt.tight_layout(rect=[0, 0.03, 1, 0.96])\n",
    "plt.savefig('semiconductor_tracker.png', dpi=150,\n",
    "            bbox_inches='tight', facecolor='#0d1117')\n",
    "plt.show()\n",
    "print(\"Chart saved as semiconductor_tracker.png\")"
   ]
